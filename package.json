{
  "name": "gridops",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted control plane for GitHub Actions runners",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "vite build && npm run build:manager && npm run build:reconciler && npm run typecheck",
    "build:manager": "esbuild src/manager/index.ts --bundle --platform=node --format=esm --target=node22 --packages=external --outfile=.output/manager/index.mjs",
    "build:reconciler": "esbuild src/reconciler/index.ts --bundle --platform=node --format=esm --target=node22 --packages=external --outfile=.output/reconciler/index.mjs",
    "start": "node .output/server/index.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests vite.config.ts drizzle.config.ts --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "manager:dev": "tsx watch src/manager/index.ts",
    "reconciler:dev": "tsx watch src/reconciler/index.ts"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.101.3",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-start": "^1.168.32",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.7",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dockerode": "^5.0.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.1.3",
    "lucide-react": "^0.552.0",
    "nanoid": "^5.1.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.4.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^3.3.47",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^27.2.0",
    "nitro": "^3.0.260311-beta",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.14",
    "vitest": "^4.0.18"
  }
}
