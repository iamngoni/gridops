# Public URL used for OAuth callbacks and webhook links.
GRIDOPS_BASE_URL=http://localhost:3000

# Override automatic webhook enablement. Set false when the HTTPS origin is
# private to a VPN/Tailscale network and GitHub cannot deliver to it.
GRIDOPS_GITHUB_WEBHOOK_ACTIVE=
# Optional public endpoint when GRIDOPS_BASE_URL itself remains private.
GRIDOPS_GITHUB_WEBHOOK_URL=

# GitHub App OAuth credentials.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional bootstrap values. Once signed in, Settings can create a correctly
# permissioned GitHub App via GitHub's manifest flow and store these encrypted.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=gridops
GITHUB_WEBHOOK_SECRET=

# Generate each value independently with: openssl rand -base64 32
GRIDOPS_SESSION_SECRET=
GRIDOPS_ENCRYPTION_KEY=

# Local, persistent runtime state.
GRIDOPS_DATABASE_PATH=./data/gridops.sqlite
GRIDOPS_LOG_DIRECTORY=./data/logs

# Docker runner manager settings.
GRIDOPS_MANAGER_URL=http://manager:8788
GRIDOPS_MANAGER_TOKEN=
GRIDOPS_RUNNER_NETWORK=gridops-runners
GRIDOPS_RUNNER_IMAGE=ghcr.io/actions/actions-runner:latest

# Optional native macOS provider. Run the Tart agent on an Apple Silicon host,
# then configure both values together. The token must be independently random.
GRIDOPS_TART_RUNNER_IMAGE=gridops-macos-tahoe-base
GRIDOPS_TART_AGENT_URL=
GRIDOPS_TART_AGENT_TOKEN=

# Native Tart agent settings (read by gridops-tart-agent, not the containers).
GRIDOPS_TART_AGENT_BIND=127.0.0.1:8790
GRIDOPS_TART_AGENT_TOKEN_FILE=
GRIDOPS_TART_AGENT_HOME=
GRIDOPS_TART_BINARY=/opt/homebrew/bin/tart
GRIDOPS_TART_RUNNER_ROOT=/Users/admin/actions-runner
GRIDOPS_TART_PULL_CONCURRENCY=8
GRIDOPS_TART_NETWORK_MODE=softnet
GRIDOPS_TART_CPU_BUDGET=4
GRIDOPS_TART_MEMORY_BUDGET_MB=6144
GRIDOPS_TART_MAX_RUNNERS=1
GRIDOPS_TART_MIN_FREE_DISK_MB=40960

# Host safety. Leave CPU, memory, and count blank to derive conservative limits
# from the Docker host (75% CPU, 75% memory, and a 2 CPU / 2 GB runner shape).
GRIDOPS_RUNNER_CPU_BUDGET=
GRIDOPS_RUNNER_MEMORY_BUDGET_MB=
GRIDOPS_MAX_MANAGED_RUNNERS=
GRIDOPS_MIN_FREE_DISK_MB=25600
GRIDOPS_MIN_FREE_DISK_PERCENT=15
GRIDOPS_PROVISIONING_PAUSED=false
GRIDOPS_RUNNER_LOG_MAX_SIZE=20m
GRIDOPS_RUNNER_LOG_MAX_FILES=5
GRIDOPS_RUNNER_PIDS_LIMIT=1024

# Only the runner-manager service receives Docker socket access.
GRIDOPS_DOCKER_SOCKET=/var/run/docker.sock
GRIDOPS_API_BIND=0.0.0.0:8080
GRIDOPS_WEB_ROOT=./dist
GRIDOPS_MANAGER_BIND=0.0.0.0:8788
GRIDOPS_BIND_ADDRESS=127.0.0.1
GRIDOPS_PORT=3000
